geom_text(aes(label = Parameter), size = 3, fontface = "italic") +
scale_fill_manual(values = c("Rodin_et_al" = "#3498db", "Our_Calls" = "#e67e22", "Taejeong" = "#9b59b6")) +
scale_x_discrete(position = "top") + # Move pipeline names to the top
theme_minimal() +
labs(title = "Detailed Pipeline Parameter Comparison", x = "", y = "") +
theme(
axis.text.x = element_text(face = "bold", size = 11),
axis.text.y = element_text(face = "bold", size = 10),
panel.grid = element_blank(),
legend.position = "none"
)
# Create the data frame
pipeline_data <- data.frame(
Step = c("Input", "Alignment", "Preprocessing", "Somatic_Caller", "MAF_Filter", "VAF_Filter", "Repeat_Filter", "Access_Mask"),
Rodin = c("Inconsistent", "Inconsistent", "Consistent", "Consistent", "Inconsistent", "Consistent", "Consistent", "Inconsistent"),
Our_Calls = c("Inconsistent", "Inconsistent", "Consistent", "Consistent", "Inconsistent", "Consistent", "Consistent", "Consistent"),
Taejeong = c("Inconsistent", "Inconsistent", "Consistent", "Inconsistent", "Inconsistent", "Inconsistent", "Consistent", "Consistent")
)
# Reshape for ggplot
plot_data <- pivot_longer(pipeline_data, cols = -Step, names_to = "Pipeline", values_to = "Status")
p1 <- ggplot(plot_data, aes(x = Pipeline, y = Step, fill = Status)) +
geom_tile(color = "white", lwd = 1) +
scale_fill_manual(values = c("Consistent" = "#2ecc71", "Inconsistent" = "#e74c3c")) +
theme_minimal() +
labs(title = "Pipeline Consistency Matrix",
subtitle = "Comparison of Bioinformatic Parameters Across Three Pipelines",
x = "", y = "") +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
df <- data.frame(
Step = rev(factor(c("Input", "Alignment", "Preprocessing", "PoN", "Caller",
"MAF Filter", "Dups/Regions", "Tag Quality", "VAF/Depth",
"Germline", "Private", "Indels", "Mask"),
levels = c("Input", "Alignment", "Preprocessing", "PoN", "Caller",
"MAF Filter", "Dups/Regions", "Tag Quality", "VAF/Depth",
"Germline", "Private", "Indels", "Mask"))),
Rodin = c("250X Raw", "hg19/hs37d5", "GATK BQSR", "73 Samples", "MuTect2",
"MAF <= 1e-5", "SegDups/Non-diploid", "t_lod/triallelic", "VAF 0.02-0.03/Alt>=3",
"VAF <= 0.40", "Filtered", "Exclude RepMask", "None"),
Our_Calls = c("40X Downsample", "hg38", "GATK BQSR", "None", "MuTect2",
"Tiered (T1/T2/T3)", "Segmental Dups", "Keep 'PASS'", "VAF 0.02-0.03/Alt>=3",
"VAF <= 0.40", "None", "Exclude RepMask", "Filter Out"),
Taejeong = c("250X BAM to FQ", "hg19/hs37d5", "GATK BQSR", "None", "Haplotype (p=50)",
"MAF <= 0.001", "Segmental Dups", "None", "Alt Depth >= 5",
"VAF != 0.5", "None", "Exclude RepMask", "Filter Out")
)
# 2. Reshape for plotting
df_long <- pivot_longer(df, cols = -Step, names_to = "Pipeline", values_to = "Parameter")
# 3. Create the Plot
p2 <- ggplot(df_long, aes(x = Pipeline, y = Step)) +
