axis.text.y = element_text(face = "bold"),
panel.grid = element_blank(),
legend.position = "none")
# 1. Define the steps in the exact order you provided
steps_ordered <- c(
"Input (FASTQ)",
"Alignment (BWA-MEM)",
"GATK Preprocessing",
"PoN Creation (MuTect2-PoN)",
"Somatic Calling",
"Filter: Population MAF",
"Filter: Duplications/Regions",
"Filter: Tag-based Quality",
"Filter: VAF/Depth",
"Filter: Germline/High VAF",
"Filter: Private Events",
"Filter: Indels-Specific",
"Filter: Accessibility Mask"
)
# 2. Create the data frame
# We use factor(..., levels = rev(steps_ordered)) so 'Input' is at the top of the Y-axis
pipeline_data <- data.frame(
Step = factor(steps_ordered, levels = rev(steps_ordered)),
Rodin_et_al = c(
"250X Raw fastq", "hg19/hs37d5 decoy", "BQSR, Realignment", "73 Individuals",
"MuTect2", "MAF <= 1e-5", "SegDups/Non-diploid", "t_lod/triallelic",
"VAF 0.02-0.03, Alt>=3", "VAF <= 0.40", "Private to population",
"Exclude Simple Reps", "None"
),
Our_Calls = c(
"40X (Downsampled)", "hg38", "BQSR, Realignment", "None",
"MuTect2", "Tiered (T1/T2/T3)", "Segmental Dups", "Keep 'PASS' tag",
"VAF 0.02-0.03, Alt>=3", "VAF <= 0.40", "None",
"Exclude Simple Reps", "Filter out"
),
Taejeong = c(
"250X (BAM to FQ)", "hg19/hs37d5 decoy", "BQSR, Realignment", "None",
"HaplotypeCaller (p=50)", "MAF <= 0.001", "Segmental Dups", "None",
"Alt Depth >= 5", "VAF != 0.5 (PON mask)", "None",
"Exclude Simple Reps", "Filter out"
)
)
# 3. Reshape for ggplot
plot_data <- pivot_longer(pipeline_data, cols = -Step, names_to = "Pipeline", values_to = "Parameter")
plot_data$Pipeline <- factor(plot_data$Pipeline, levels = c("Rodin_et_al", "Our_Calls", "Taejeong"))
# 4. Generate Plot
ggplot(plot_data, aes(x = Pipeline, y = Step)) +
geom_tile(aes(fill = Pipeline), color = "black", alpha = 0.2) +
geom_text(aes(label = Parameter), size = 3, fontface = "italic") +
scale_fill_manual(values = c("Rodin_et_al" = "#3498db", "Our_Calls" = "#e67e22", "Taejeong" = "#9b59b6")) +
scale_x_discrete(position = "top") + # Move pipeline names to the top
theme_minimal() +
labs(title = "Detailed Pipeline Parameter Comparison", x = "", y = "") +
theme(
axis.text.x = element_text(face = "bold", size = 11),
