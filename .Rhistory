library(rvest)
library(dplyr)
library(ggplot2)
library(stringr)
url <- "https://www.datasciencemeta.com/rpackages"
# 1. Read the HTML and extract the first table found on the page
df <- url %>%
read_html() %>%
html_table() %>%
.[[1]]
colnames(df)[2] <- c("Package_Name")
df_clean <- df %>%
mutate(Downloads_num = as.numeric(str_remove_all(Downloads, ",")))
nrow(df_clean)
df_clean$Downloads_num[23078/2+1]
which(df_clean$Downloads_num %in% median(df_clean$Downloads_num, na.rm = TRUE))
# 2. Calculate the median
median_val <- median(df_clean$Downloads_num, na.rm = TRUE)
# 3. Print the result
stepreg_info <- df_clean[df_clean$Package_Name=="StepReg",]
# 4. Print the result
cat("total R packages:", nrow(df_clean))
cat("The median download count for all R packages is:", median_val)
cat("The download count for StepReg is:", stepreg_info$Downloads_num)
cat("The download times for StepReg raletive to the median is:", stepreg_info$Downloads_num / median_val)
cat("StepReg is in the top of most downloaded R packages:", stepreg_info$Rank / nrow(df_clean) * 100, "%")
library(rvest)
library(dplyr)
library(ggplot2)
library(stringr)
url <- "https://www.datasciencemeta.com/rpackages"
# 1. Read the HTML and extract the first table found on the page
df <- url %>%
read_html() %>%
html_table() %>%
.[[1]]
colnames(df)[2] <- c("Package_Name")
df_clean <- df %>%
mutate(Downloads_num = as.numeric(str_remove_all(Downloads, ",")))
nrow(df_clean)
df_clean$Downloads_num[23078/2+1]
which(df_clean$Downloads_num %in% median(df_clean$Downloads_num, na.rm = TRUE))
# 2. Calculate the median
median_val <- median(df_clean$Downloads_num, na.rm = TRUE)
# 3. Print the result
stepreg_info <- df_clean[df_clean$Package_Name=="StepReg",]
cat("total R packages:", nrow(df_clean))
cat("The median download count for all R packages is:", median_val)
cat("The download count for StepReg is:", stepreg_info$Downloads_num)
cat("The download times for StepReg raletive to the median is:", stepreg_info$Downloads_num / median_val)
cat("StepReg is in the top of most downloaded R packages:", stepreg_info$Rank / nrow(df_clean) * 100, "%")
